generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  createdAt          DateTime            @default(now())
  passwordHash       String
  updatedAt          DateTime            @default(now()) @updatedAt
  eventRegistrations EventRegistration[]
  uploadedFiles      File[]
  invitationsSent    Invitation[]        @relation("InvitationInvitedBy")
  memberships        Membership[]
  notifications      Notification[]
}

model Association {
  id                   String         @id @default(cuid())
  name                 String
  createdAt            DateTime       @default(now())
  description          String?
  isActive             Boolean        @default(true)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  logoUrl              String?
  updatedAt            DateTime       @default(now()) @updatedAt
  events               Event[]
  files                File[]
  invitations          Invitation[]
  memberships          Membership[]
  notifications        Notification[]
  transactions         Transaction[]
}

model Membership {
  id            String      @id @default(cuid())
  userId        String
  associationId String
  createdAt     DateTime    @default(now())
  role          Role        @default(MEMBER)
  updatedAt     DateTime    @default(now()) @updatedAt
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, associationId])
}

model Invitation {
  id            String      @id @default(cuid())
  email         String
  role          Role        @default(MEMBER)
  token         String      @unique
  acceptedAt    DateTime?
  expiresAt     DateTime
  associationId String
  invitedById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  invitedBy     User        @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([email, associationId])
}

model Event {
  id            String              @id @default(cuid())
  associationId String
  title         String
  description   String?
  location      String?
  startsAt      DateTime
  endsAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt
  association   Association         @relation(fields: [associationId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Notification {
  id            String       @id @default(cuid())
  title         String
  message       String
  read          Boolean      @default(false)
  associationId String?
  userId        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  association   Association? @relation(fields: [associationId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String      @id @default(cuid())
  associationId String
  type          String
  category      String?
  description   String?
  amountCents   Int
  date          DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  title         String?
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
}

model File {
  id            String      @id @default(cuid())
  filename      String
  originalName  String
  mimetype      String
  size          Int
  path          String
  associationId String
  uploadedById  String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  uploadedBy    User        @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}
